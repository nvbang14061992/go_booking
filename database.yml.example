development:
  dialect: postgres
  database: booking_db_name
  user: your_username
  password: your_passowrd
  host: localhost
  port: postgres_port
  pool: 5

test:
  url: {{envOr "TEST_DATABASE_URL" "postgres://admin:1234@localhost:5432/myapp_test"}}

production:
  url: {{envOr "DATABASE_URL" "postgres://admin:1234@localhost:5432/myapp_production"}}
